generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  price       Float
  imageUrl    String?
  type        String   @default("Sell") // Sell, Rent, Both
  sizes       String?  // Comma-separated sizes e.g., "S,M,L"
  colors      String?  // Comma-separated colors e.g., "Red,Blue"
  category    String   // Wedding, Suit, Shoes, Gown, Thrift, New, Underwear
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Settings {
  id        Int      @id @default(1)
  address   String   @default("123 Rue de la Seremoni, Port-au-Prince, Haiti")
  phone1    String   @default("+509 3000-0000")
  phone2    String   @default("+509 4000-0000")
  whatsapp  String   @default("50940000000") // Only numbers for WhatsApp links
  email     String   @default("info@c-remonie.com")
}
